# name: test/sql/glob/h5_glob_pushdown.test
# description: predicate pushdown coverage for globbed h5_read over RSE columns
# group: [glob]

require h5db

statement ok
PRAGMA enable_profiling='json';

statement ok
PRAGMA profiling_output='h5db_glob_pushdown_profile.json';

query I
SELECT COUNT(*)
FROM h5_read(
    'test/data/glob_pushdown/pushdown_*.h5',
    '/regular',
    h5_rse('/int_rse_starts', '/int_rse_values')
)
WHERE int_rse_values = 30;
----
400

statement ok
PRAGMA disable_profiling;

query I
SELECT COUNT(*)
FROM read_text('h5db_glob_pushdown_profile.json')
WHERE contains(
    substr(content, greatest(strpos(content, '"operator_name": "H5_READ"') - 260, 1), 520),
    '"operator_cardinality": 400'
);
----
1

