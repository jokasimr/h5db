statement ok
PRAGMA profiling_output='h5db_glob_pushdown_profile.json';

query I
SELECT COUNT(*)
FROM h5_read(
    'test/data/glob_pushdown/**/pushdown_*.h5',
    '/regular',
    h5_rse('/int_rse_starts', '/int_rse_values'),
    h5_rse('/float_rse_starts', '/float_rse_values')
)
WHERE int_rse_values = 30 AND float_rse_values = 3.5;
----
600

statement ok
PRAGMA disable_profiling;

query I
