query III
SELECT replace(filename, '\', '/') AS filename, idx, values
FROM h5_read(
    'test/data/glob_order/order_*.h5',
    h5_alias('idx', h5_index()),
    '/values'
)
ORDER BY filename, idx;
----
test/data/glob_order/order_1.h5	0	1
test/data/glob_order/order_10.h5	0	10
test/data/glob_order/order_2.h5	0	2

query III
SELECT values, replace(filename, '\', '/') AS filename, idx
FROM h5_read(
    'test/data/glob_order/order_*.h5',
    '/values',
    h5_alias('idx', h5_index())
)
WHERE idx = 0
ORDER BY filename;
----
1	test/data/glob_order/order_1.h5	0
10	test/data/glob_order/order_10.h5	0
2	test/data/glob_order/order_2.h5	0

query III
SELECT replace(source, '\', '/') AS source, idx, values
FROM h5_read(
    'test/data/glob_order/order_*.h5',
    h5_alias('idx', h5_index()),
    '/values',
    filename='source'
)
ORDER BY source, idx;
----
test/data/glob_order/order_1.h5	0	1
test/data/glob_order/order_10.h5	0	10
test/data/glob_order/order_2.h5	0	2

