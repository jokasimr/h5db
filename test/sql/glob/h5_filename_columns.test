# name: test/sql/glob/h5_filename_columns.test
# description: hidden and visible filename columns for h5_tree, h5_ls, and h5_read
# group: [glob]

require h5db

query TTTTTT
DESCRIBE FROM h5_tree('test/data/glob_order/order_1.h5');
----
path	VARCHAR	YES	NULL	NULL	NULL
type	VARCHAR	YES	NULL	NULL	NULL
dtype	VARCHAR	YES	NULL	NULL	NULL
shape	UBIGINT[]	YES	NULL	NULL	NULL

query TTTTTT
DESCRIBE FROM h5_tree('test/data/glob_order/order_1.h5', filename=true);
----
path	VARCHAR	YES	NULL	NULL	NULL
type	VARCHAR	YES	NULL	NULL	NULL
dtype	VARCHAR	YES	NULL	NULL	NULL
shape	UBIGINT[]	YES	NULL	NULL	NULL
filename	VARCHAR	YES	NULL	NULL	NULL

query TTTTTT
DESCRIBE FROM h5_tree('test/data/glob_order/order_1.h5', filename='source');
----
path	VARCHAR	YES	NULL	NULL	NULL
type	VARCHAR	YES	NULL	NULL	NULL
dtype	VARCHAR	YES	NULL	NULL	NULL
shape	UBIGINT[]	YES	NULL	NULL	NULL
source	VARCHAR	YES	NULL	NULL	NULL

query TTTTTT
DESCRIBE FROM h5_tree('test/data/glob_order/order_1.h5', filename=false);
----
path	VARCHAR	YES	NULL	NULL	NULL
type	VARCHAR	YES	NULL	NULL	NULL
dtype	VARCHAR	YES	NULL	NULL	NULL
shape	UBIGINT[]	YES	NULL	NULL	NULL

query IIII
FROM h5_tree('test/data/glob_order/order_1.h5') LIMIT 1;
----
/	group	NULL	NULL

query IIIII
SELECT path, type, dtype, shape, replace(filename, '\', '/')
FROM h5_tree('test/data/glob_order/order_1.h5', filename=true) LIMIT 1;
----
/	group	NULL	NULL	test/data/glob_order/order_1.h5

query IIIII
SELECT path, type, dtype, shape, replace(source, '\', '/')
FROM h5_tree('test/data/glob_order/order_1.h5', filename='source') LIMIT 1;
----
/	group	NULL	NULL	test/data/glob_order/order_1.h5

query II
SELECT replace(filename, '\', '/') AS filename, path
FROM h5_tree('test/data/glob_order/order_*.h5')
WHERE path LIKE '/marker_%'
ORDER BY filename, path;
----
test/data/glob_order/order_1.h5	/marker_1
test/data/glob_order/order_10.h5	/marker_10
test/data/glob_order/order_2.h5	/marker_2

query II
SELECT replace(source, '\', '/') AS source, path
FROM h5_tree('test/data/glob_order/order_*.h5', filename='source')
WHERE path LIKE '/marker_%'
ORDER BY source, path;
----
test/data/glob_order/order_1.h5	/marker_1
test/data/glob_order/order_10.h5	/marker_10
test/data/glob_order/order_2.h5	/marker_2

statement error
SELECT filename
FROM h5_tree('test/data/glob_order/order_1.h5', filename='source');
----
<REGEX>:.*filename.*not found.*

query I
SELECT replace(filename, '\', '/') AS filename
FROM h5_tree('test/data/glob_order/order_1.h5', filename=false)
WHERE path = '/marker_1';
----
test/data/glob_order/order_1.h5

statement error
FROM h5_tree('test/data/glob_order/order_1.h5', filename=NULL);
----
Invalid Input Error: Cannot use NULL as argument for "filename"

query I
SELECT replace(filename, '\', '/') AS filename
FROM h5_tree([
    'test/data/glob_order/order_1.h5',
    'test/data/glob_order/order_1.h5'
])
WHERE path = '/marker_1'
ORDER BY ALL;
----
test/data/glob_order/order_1.h5
test/data/glob_order/order_1.h5

# Filename filter pushdown should skip filtered-out files before opening them.
query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
])
WHERE filename = 'test/data/simple.h5';
----
10

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
])
WHERE filename IN ('test/data/simple.h5', 'test/data/other.h5');
----
10

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
])
WHERE filename LIKE '%/simple.h5';
----
10

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
], filename=true)
WHERE filename = 'test/data/simple.h5' AND path = '/';
----
1

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
], filename='source')
WHERE source = 'test/data/simple.h5' AND path = '/';
----
1

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
], filename='source')
WHERE source = 'test/data/no_match.h5';
----
0

query I
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
])
WHERE filename = 'test/data/no_match.h5';
----
0

statement error
SELECT COUNT(*)
FROM h5_tree([
    'test/data/does_not_exist_filename_pushdown.h5',
    'test/data/simple.h5'
])
WHERE filename = 'test/data/no_match.h5' OR path = '/';
----
<REGEX>:.*Failed to open HDF5 file: test[\\\\/]data[\\\\/]does_not_exist_filename_pushdown\.h5.*

statement error
FROM h5_tree('test/data/simple.h5', filename='path');
----
Binder Error: Option filename adds column "path", but that column name is already present in h5_tree output

statement error
FROM h5_tree('test/data/simple.h5', filename='PATH');
----
Binder Error: Option filename adds column "PATH", but that column name is already present in h5_tree output

statement error
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('filename', h5_attr('string_attr')),
    filename=true
);
----
Binder Error: Option filename adds column "filename", but that column name is already present in h5_tree output

statement error
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('source', h5_attr('string_attr')),
    filename='source'
);
----
Binder Error: Option filename adds column "source", but that column name is already present in h5_tree output

statement error
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('FiLeNaMe', h5_attr('string_attr')),
    filename=true
);
----
Binder Error: Option filename adds column "filename", but that column name is already present in h5_tree output

statement error
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('SoUrCe', h5_attr('string_attr')),
    filename='source'
);
----
Binder Error: Option filename adds column "source", but that column name is already present in h5_tree output

query I
SELECT filename
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('filename', h5_attr('string_attr'))
)
WHERE path = '/dataset_with_attrs';
