# name: test/sql/empty_scalar.test
# description: Empty and scalar dataset edge cases
# group: [sql]

require h5db

# =============================================================================
# h5_tree reporting
# =============================================================================

query IIII
SELECT
    COUNT(*) FILTER (WHERE path = '/scalar_int' AND dtype = 'int32' AND shape = []),
    COUNT(*) FILTER (WHERE path = '/empty_1d' AND dtype = 'int32' AND shape = [0]),
    COUNT(*) FILTER (WHERE path = '/null_int' AND type = 'dataset' AND dtype = 'int32' AND shape IS NULL),
    COUNT(*) FILTER (WHERE path = '/null_str' AND type = 'dataset' AND dtype = 'string' AND shape IS NULL)
FROM h5_tree('test/data/empty_scalar.h5');
----
1	1	1	1

query III
SELECT
    COUNT(*) FILTER (WHERE path = '/scalar_int' AND shape = []),
    COUNT(*) FILTER (WHERE path = '/null_int' AND shape IS NULL),
    COUNT(*) FILTER (WHERE path = '/null_str' AND shape IS NULL)
FROM h5_ls('test/data/empty_scalar.h5', '/');
----
1	1	1

query III
SELECT
    CASE WHEN struct_extract(map_extract_value(children, 'scalar_int'), 'shape') = [] THEN 1 ELSE 0 END,
    CASE WHEN struct_extract(map_extract_value(children, 'null_int'), 'shape') IS NULL THEN 1 ELSE 0 END,
    CASE WHEN struct_extract(map_extract_value(children, 'null_str'), 'shape') IS NULL THEN 1 ELSE 0 END
FROM (
    SELECT h5_ls('test/data/empty_scalar.h5', '/') AS children
);
----
1	1	1

# =============================================================================
# Scalar datasets should be read and treated as constants
# =============================================================================

query II
SELECT scalar_int, scalar_str FROM h5_read('test/data/empty_scalar.h5', '/scalar_int', '/scalar_str');
----
7	hello

query III
SELECT COUNT(*), MIN(scalar_int), MIN(scalar_str)
FROM h5_read('test/data/empty_scalar.h5', '/scalar_int', '/scalar_str', '/long');
----
5	7	hello

# Null dataspaces behave like scalar datasets whose value is SQL NULL.
query II
SELECT COUNT(*), COUNT(null_int)
FROM h5_read('test/data/empty_scalar.h5', '/null_int');
----
1	0

query IIII
SELECT COUNT(*), COUNT(null_int), COUNT(null_str), MIN(scalar_int)
FROM h5_read(
    'test/data/empty_scalar.h5',
    '/null_int',
    '/null_str',
    '/scalar_int'
);
----
1	0	0	7

query III
SELECT COUNT(*), COUNT(null_int), COUNT(*) FILTER (WHERE null_int IS NULL)
FROM h5_read('test/data/empty_scalar.h5', '/null_int', '/long');
----
5	0	5

query TT
SELECT typeof(null_int), typeof(null_str)
FROM h5_read('test/data/empty_scalar.h5', '/null_int', '/null_str');
----
INTEGER	VARCHAR

query II
SELECT
    CASE WHEN h5_read('test/data/empty_scalar.h5', '/null_int') IS NULL THEN 1 ELSE 0 END,
    CASE WHEN h5_read('test/data/empty_scalar.h5', '/null_str') IS NULL THEN 1 ELSE 0 END;
----
1	1

query II
SELECT index, CASE WHEN null_int IS NULL THEN 1 ELSE 0 END
FROM h5_read('test/data/empty_scalar.h5', h5_index(), '/null_int');
----
0	1

query TITT
SELECT
    variant_typeof(h5_read('test/data/empty_scalar.h5', '/scalar_int')),
    TRY_CAST(h5_read('test/data/empty_scalar.h5', '/scalar_int') AS INTEGER),
    variant_typeof(h5_read('test/data/empty_scalar.h5', '/scalar_str')),
    TRY_CAST(h5_read('test/data/empty_scalar.h5', '/scalar_str') AS VARCHAR);
----
INT32	7	VARCHAR	hello

query TTT
WITH paths(path) AS (
    VALUES ('/scalar_int'), ('/scalar_str'), (NULL::VARCHAR)
),
values AS (
    SELECT path, h5_read('test/data/empty_scalar.h5', path) AS value
    FROM paths
)
SELECT
    COALESCE(path, '<null>') AS path,
    CASE WHEN value IS NULL THEN 'NULL' ELSE variant_typeof(value) END AS value_type,
    TRY_CAST(value AS VARCHAR) AS value_text
FROM values
ORDER BY path;
----
/scalar_int	INT32	7
/scalar_str	VARCHAR	hello
<null>	NULL	NULL

query TII
WITH inputs(filename, path) AS (
    VALUES
        ('test/data/empty_scalar.h5', '/scalar_int'),
        (NULL::VARCHAR, '/scalar_int')
),
values AS (
    SELECT filename, h5_read(filename, path) AS value
    FROM inputs
)
SELECT
    COALESCE(filename, '<null>') AS filename,
    CASE WHEN value IS NULL THEN 1 ELSE 0 END AS is_null,
    TRY_CAST(value AS INTEGER) AS value_int
FROM values
ORDER BY filename;
----
<null>	1	NULL
test/data/empty_scalar.h5	0	7

