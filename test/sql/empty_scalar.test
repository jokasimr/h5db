# name: test/sql/empty_scalar.test
# description: Empty and scalar dataset edge cases
# group: [sql]

require h5db

# =============================================================================
# h5_tree reporting
# =============================================================================

query II
SELECT
    COUNT(*) FILTER (WHERE path = '/scalar_int' AND dtype = 'int32' AND shape = []),
    COUNT(*) FILTER (WHERE path = '/empty_1d' AND dtype = 'int32' AND shape = [0])
FROM h5_tree('test/data/empty_scalar.h5');
----
1	1

# =============================================================================
# Scalar datasets should be read and treated as constants
# =============================================================================

query II
SELECT scalar_int, scalar_str FROM h5_read('test/data/empty_scalar.h5', '/scalar_int', '/scalar_str');
----
7	hello

query III
SELECT COUNT(*), MIN(scalar_int), MIN(scalar_str)
FROM h5_read('test/data/empty_scalar.h5', '/scalar_int', '/scalar_str', '/long');
----
5	7	hello

query TITT
SELECT
    variant_typeof(h5_read('test/data/empty_scalar.h5', '/scalar_int')),
    TRY_CAST(h5_read('test/data/empty_scalar.h5', '/scalar_int') AS INTEGER),
    variant_typeof(h5_read('test/data/empty_scalar.h5', '/scalar_str')),
    TRY_CAST(h5_read('test/data/empty_scalar.h5', '/scalar_str') AS VARCHAR);
----
INT32	7	VARCHAR	hello

query TTT
WITH paths(path) AS (
    VALUES ('/scalar_int'), ('/scalar_str'), (NULL::VARCHAR)
),
values AS (
    SELECT path, h5_read('test/data/empty_scalar.h5', path) AS value
    FROM paths
)
SELECT
    COALESCE(path, '<null>') AS path,
    CASE WHEN value IS NULL THEN 'NULL' ELSE variant_typeof(value) END AS value_type,
    TRY_CAST(value AS VARCHAR) AS value_text
FROM values
ORDER BY path;
----
/scalar_int	INT32	7
/scalar_str	VARCHAR	hello
<null>	NULL	NULL

query TII
WITH inputs(filename, path) AS (
    VALUES
        ('test/data/empty_scalar.h5', '/scalar_int'),
        (NULL::VARCHAR, '/scalar_int')
),
values AS (
    SELECT filename, h5_read(filename, path) AS value
    FROM inputs
)
SELECT
    COALESCE(filename, '<null>') AS filename,
    CASE WHEN value IS NULL THEN 1 ELSE 0 END AS is_null,
    TRY_CAST(value AS INTEGER) AS value_int
FROM values
ORDER BY filename;
----
<null>	1	NULL
test/data/empty_scalar.h5	0	7

statement error
SELECT h5_read('test/data/empty_scalar.h5', '/missing');
----
IO Error: Failed to open dataset: /missing in file: test/data/empty_scalar.h5

statement error
SELECT h5_read('nonexistent.h5', '/scalar_int');
----
IO Error: Failed to open HDF5 file: nonexistent.h5

statement error
SELECT h5_read('test/data/glob/no_such_*.h5', '/scalar_int');
----
IO Error: Failed to open HDF5 file: test/data/glob/no_such_*.h5

statement error
SELECT h5_read('test/data/empty_scalar.h5', '/');
----
IO Error: Failed to open dataset: / in file: test/data/empty_scalar.h5

statement error
SELECT h5_read('test/data/empty_scalar.h5', '/long');
----
IO Error: Scalar h5_read only supports scalar datasets: /long in file: test/data/empty_scalar.h5

statement error
SELECT h5_read('test/data/empty_scalar.h5', '/scalar_int', swmr := true);
----
<REGEX>:.*No function matches the given name and argument types 'h5_read\(STRING_LITERAL, STRING_LITERAL, BOOLEAN\)'.*

statement error
SELECT h5_read(['test/data/empty_scalar.h5'], '/scalar_int');
----
<REGEX>:.*No function matches the given name and argument types 'h5_read\(VARCHAR\[\], STRING_LITERAL\)'.*

query I
SELECT COUNT(*)
FROM h5_read('test/data/empty_scalar.h5', '/scalar_int', '/empty_1d');
----
0

# =============================================================================
# Null and empty strings
# =============================================================================

query II
SELECT
    COUNT(*) FILTER (WHERE null_strings IS NULL),
    COUNT(*) FILTER (WHERE null_strings = '')
FROM h5_read('test/data/empty_scalar.h5', '/null_strings');
----
0	2

# =============================================================================
# Empty datasets should yield zero rows
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/empty_scalar.h5', '/empty_1d');
----
0

query I
SELECT COUNT(*) FROM h5_read('test/data/empty_scalar.h5', '/empty_2d');
----
0

# =============================================================================
# Multi-file empty and scalar-only edge cases
# =============================================================================

query III
SELECT COUNT(*), SUM(values), COUNT(DISTINCT filename)
FROM h5_read([
    'test/data/h5_read_multifile_empty_b.h5',
    'test/data/h5_read_multifile_empty_a.h5',
    'test/data/h5_read_multifile_empty_b.h5',
    'test/data/h5_read_multifile_empty_c.h5'
], '/values');
----
5	63	2

query TI
SELECT replace(filename, '\', '/') AS filename, SUM(values)
FROM h5_read([
    'test/data/h5_read_multifile_empty_a.h5',
    'test/data/h5_read_multifile_empty_b.h5',
    'test/data/h5_read_multifile_empty_c.h5'
], '/values')
GROUP BY filename
ORDER BY filename;
----
test/data/h5_read_multifile_empty_a.h5	3
test/data/h5_read_multifile_empty_c.h5	60

query I
SELECT COUNT(*)
FROM h5_read([
    'test/data/h5_read_multifile_empty_b.h5',
    'test/data/h5_read_multifile_empty_b.h5'
], '/values');
----
0

query III
SELECT COUNT(*), SUM(scalar), COUNT(DISTINCT filename)
FROM h5_read([
    'test/data/h5_read_multifile_empty_a.h5',
    'test/data/h5_read_multifile_empty_b.h5',
    'test/data/h5_read_multifile_empty_c.h5'
], '/scalar');
----
3	60	3

# =============================================================================
# Row count uses minimum across datasets
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/empty_scalar.h5', '/short', '/long');
----
2

query I
SELECT COUNT(*) FROM h5_read('test/data/empty_scalar.h5', '/empty_1d', '/long');
----
0

# =============================================================================
# h5_index is not a regular dataset for row count
# =============================================================================

statement error
SELECT * FROM h5_read(
    'test/data/run_encoded.h5',
    h5_index(),
    h5_rse('/experiment1/state_run_starts', '/experiment1/state_values')
);
----
IO Error: h5_read requires at least one regular column

# =============================================================================
# Row count determination with regular/scalar/rse/index combinations
# =============================================================================

statement error
SELECT * FROM h5_read('test/data/simple.h5', h5_index());
----
IO Error: h5_read requires at least one regular column

statement error
SELECT * FROM h5_read('test/data/run_encoded.h5', h5_rse('/experiment1/state_run_starts', '/experiment1/state_values'));
----
IO Error: h5_read requires at least one regular column

statement error
SELECT * FROM h5_read(
    'test/data/empty_scalar.h5',
    '/scalar_int',
    h5_rse('/rse_run_starts', '/rse_values')
);
----
IO Error: h5_read requires at least one non-scalar regular column when using run-encoded columns to determine row count

statement error
SELECT * FROM h5_read(
    'test/data/empty_scalar.h5',
    '/scalar_int',
    h5_ree('/rse_run_starts', '/rse_values')
);
----
IO Error: h5_read requires at least one non-scalar regular column when using run-encoded columns to determine row count

statement error
SELECT * FROM h5_read(
    'test/data/empty_scalar.h5',
    h5_index(),
    h5_rse('/rse_run_starts', '/rse_values')
);
----
IO Error: h5_read requires at least one regular column

query II
SELECT index, scalar_int FROM h5_read('test/data/empty_scalar.h5', h5_index(), '/scalar_int');
----
0	7

query III
SELECT index, scalar_int, long
FROM h5_read('test/data/empty_scalar.h5', h5_index(), '/scalar_int', '/long')
ORDER BY index;
----
0	7	0
1	7	1
2	7	2
3	7	3
4	7	4
