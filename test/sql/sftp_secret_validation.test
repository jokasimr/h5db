# name: test/sql/sftp_secret_validation.test
# description: test sftp secret validation
# group: [sql]

require h5db

# =============================================================================
# SFTP Secret Validation Tests
# =============================================================================

statement error
CREATE OR REPLACE TEMPORARY SECRET sftp_missing_username (
    TYPE sftp,
    SCOPE 'sftp://example.com/',
    PASSWORD 'pw',
    KNOWN_HOSTS_PATH '/tmp/known_hosts'
);
----
Invalid Input Error: sftp secret requires USERNAME

statement error
CREATE OR REPLACE TEMPORARY SECRET sftp_bad_port (
    TYPE sftp,
    SCOPE 'sftp://example.com/',
    USERNAME 'alice',
    PASSWORD 'pw',
    KNOWN_HOSTS_PATH '/tmp/known_hosts',
    PORT 70000
);
----
Invalid Input Error: sftp secret PORT must be between 1 and 65535

statement error
SELECT COUNT(*) FROM h5_tree('sftp://example.com:notaport/file.h5');
----
Invalid Input Error: Invalid port in sftp URL: sftp://example.com:notaport/file.h5

statement error
CREATE OR REPLACE TEMPORARY SECRET sftp_both_password_and_key_path (
    TYPE sftp,
    SCOPE 'sftp://example.com/',
    USERNAME 'alice',
    PASSWORD 'pw',
    KEY_PATH '/tmp/id_ed25519',
    KNOWN_HOSTS_PATH '/tmp/known_hosts'
);
----
Invalid Input Error: sftp secret requires exactly one of PASSWORD or KEY_PATH

statement error
CREATE OR REPLACE TEMPORARY SECRET sftp_missing_auth_material (
    TYPE sftp,
    SCOPE 'sftp://example.com/',
    USERNAME 'alice',
    KNOWN_HOSTS_PATH '/tmp/known_hosts'
);
----
Invalid Input Error: sftp secret requires either PASSWORD or KEY_PATH

statement error
CREATE OR REPLACE TEMPORARY SECRET sftp_missing_trust_material (
    TYPE sftp,
    SCOPE 'sftp://example.com/',
    USERNAME 'alice',
    PASSWORD 'pw'
);
----
Invalid Input Error: sftp secret requires either KNOWN_HOSTS_PATH or HOST_KEY_FINGERPRINT
