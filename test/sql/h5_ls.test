query TII
WITH paths(path) AS (
    VALUES ('/'), ('/group')
)
SELECT
    path,
    struct_extract(map_extract_value(h5_ls('test/data/links.h5', path, h5_attr('attr', -1::INTEGER)), 'named_int32'), 'attr'),
    struct_extract(map_extract_value(h5_ls('test/data/links.h5', path, h5_attr('attr', -1::INTEGER)), 'data'), 'attr')
FROM paths
