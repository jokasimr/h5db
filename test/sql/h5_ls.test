query I
SELECT struct_extract(map_extract_value(h5_ls('test/data/links.h5', '/', h5_attr('attr', -1::INTEGER)), 'external_link'), 'attr');
----
-1

query TTIII
SELECT
    typeof(labels_array),
    variant_typeof(labels_variant),
    CASE WHEN labels_array = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(labels_variant AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'labels') AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END
FROM h5_ls(
    'test/data/root_attrs.h5',
    '/',
    h5_attr(),
    h5_alias('labels_variant', h5_attr('labels')),
    h5_alias('labels_array', h5_attr('labels', ['', '', '']::VARCHAR[]))
)
WHERE path = '/string_array_attrs';
----
VARCHAR[]	ARRAY(3)	1	1	1

query TTII
SELECT
    typeof(labels_blobs),
    octet_length(array_extract(labels_blobs, 2)),
    hex(array_extract(labels_blobs, 2)),
    length(labels_blobs)
FROM h5_ls(
    'test/data/root_attrs.h5',
    '/',
    h5_alias('labels_blobs', h5_attr('labels', []::BLOB[]))
)
WHERE path = '/string_array_attrs';
----
BLOB[]	2	6262	3

query TTIII
WITH entry AS (
    SELECT map_extract_value(
        h5_ls(
            'test/data/root_attrs.h5',
            '/',
            h5_attr(),
            h5_alias('labels_variant', h5_attr('labels')),
            h5_alias('labels_array', h5_attr('labels', ['', '', '']::VARCHAR[]))
        ),
        'string_array_attrs'
    ) AS value
)
SELECT
    typeof(struct_extract(value, 'labels_array')),
    variant_typeof(struct_extract(value, 'labels_variant')),
    CASE WHEN struct_extract(value, 'labels_array') = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(struct_extract(value, 'labels_variant') AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(struct_extract(value, 'h5_attr'), 'labels') AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END
FROM entry;
----
VARCHAR[]	ARRAY(3)	1	1	1

query TTTTIIIIII
SELECT
    typeof(empty_numbers_list),
    typeof(empty_labels_list),
    variant_typeof(empty_numbers_variant),
    variant_typeof(empty_labels_variant),
    CASE WHEN empty_numbers_list = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(empty_numbers_variant AS INTEGER[]) = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'empty_numbers') AS INTEGER[]) = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN empty_labels_list = []::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(empty_labels_variant AS VARCHAR[]) = []::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'empty_labels') AS VARCHAR[]) = []::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_ls(
    'test/data/root_attrs.h5',
    '/',
    h5_attr(),
    h5_alias('empty_numbers_variant', h5_attr('empty_numbers')),
    h5_alias('empty_numbers_list', h5_attr('empty_numbers', []::INTEGER[])),
    h5_alias('empty_labels_variant', h5_attr('empty_labels')),
    h5_alias('empty_labels_list', h5_attr('empty_labels', []::VARCHAR[]))
)
WHERE path = '/empty_array_attrs';
----
INTEGER[]	VARCHAR[]	ARRAY(0)	ARRAY(0)	1	1	1	1	1	1

