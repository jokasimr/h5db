# name: test/sql/h5_ls.test
# description: h5_ls scalar and table functions
# group: [sql]

require h5db

statement error
SELECT COUNT(*) FROM h5_ls(NULL::VARCHAR, '/');
----
Parser Error: h5_ls cannot take NULL list as parameter

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE type = 'dataset')
FROM h5_ls('test/data/links.h5', '/');
----
10	2

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE type = 'dataset')
FROM h5_ls('test/data/links.h5');
----
10	2

query TI
SELECT path, attr
FROM h5_ls('test/data/links.h5', '/group', h5_attr('attr', -1::INTEGER))
ORDER BY path;
----
/group/data	7

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE attr = 13)
FROM h5_ls('test/data/links.h5', h5_attr('attr', -1::INTEGER));
----
10	1

query I
SELECT cardinality(h5_ls('test/data/links.h5', '/'));
----
10

query TTI
SELECT
    struct_extract(map_extract_value(h5_ls('test/data/links.h5', '/'), 'named_int32'), 'path'),
    struct_extract(map_extract_value(h5_ls('test/data/links.h5', '/'), 'named_int32'), 'type'),
    struct_extract(map_extract_value(h5_ls('test/data/links.h5', '/', h5_attr('attr', -1::INTEGER)), 'named_int32'), 'attr');
----
/named_int32	datatype	13

query T
SELECT
    variant_typeof(struct_extract(map_extract_value(h5_ls('test/data/links.h5', '/', h5_attr('attr')), 'named_int32'), 'attr'));
----
INT32

query TTI
SELECT path, typeof(h5_attr), cardinality(h5_attr)
FROM h5_ls('test/data/attrs_edge_cases.h5', '/', h5_attr())
WHERE path = '/empty_group';
----
/empty_group	MAP(VARCHAR, VARIANT)	0

query TI
SELECT path, CASE WHEN h5_attr IS NULL THEN 1 ELSE 0 END
FROM h5_ls('test/data/links.h5', '/', h5_attr())
WHERE path IN ('/dangling_link', '/external_link')
ORDER BY path;
----
/dangling_link	1
/external_link	1

