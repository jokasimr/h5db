query TTTITTTITTTITTTI
SELECT
    variant_typeof(struct_extract(row_value, 'invalid_utf8_string_array_attr')),
    variant_typeof(array_extract(TRY_CAST(struct_extract(row_value, 'invalid_utf8_string_array_attr') AS VARIANT[]), 1)),
    hex(CAST(array_extract(TRY_CAST(struct_extract(row_value, 'invalid_utf8_string_array_attr') AS VARIANT[]), 1) AS BLOB)),
    length(TRY_CAST(struct_extract(row_value, 'invalid_utf8_string_array_attr') AS VARIANT[])),
    typeof(struct_extract(row_value, 'invalid_utf8_string_array_vlist')),
    variant_typeof(array_extract(struct_extract(row_value, 'invalid_utf8_string_array_vlist'), 1)),
    hex(CAST(array_extract(struct_extract(row_value, 'invalid_utf8_string_array_vlist'), 1) AS BLOB)),
    length(struct_extract(row_value, 'invalid_utf8_string_array_vlist')),
    typeof(struct_extract(row_value, 'invalid_utf8_string_array_varray')),
    variant_typeof(array_extract(struct_extract(row_value, 'invalid_utf8_string_array_varray'), 1)),
    hex(CAST(array_extract(struct_extract(row_value, 'invalid_utf8_string_array_varray'), 1) AS BLOB)),
    length(struct_extract(row_value, 'invalid_utf8_string_array_varray')),
    variant_typeof(map_extract_value(struct_extract(row_value, 'h5_attr'), 'invalid_utf8_string_array_attr')),
    variant_typeof(array_extract(TRY_CAST(map_extract_value(struct_extract(row_value, 'h5_attr'), 'invalid_utf8_string_array_attr') AS VARIANT[]), 1)),
    hex(CAST(array_extract(TRY_CAST(map_extract_value(struct_extract(row_value, 'h5_attr'), 'invalid_utf8_string_array_attr') AS VARIANT[]), 1) AS BLOB)),
    length(TRY_CAST(map_extract_value(struct_extract(row_value, 'h5_attr'), 'invalid_utf8_string_array_attr') AS VARIANT[]))
FROM (
    SELECT map_extract_value(
        h5_ls(
            'test/data/invalid_string_array_attrs.h5',
            '/',
            h5_attr(),
            h5_attr('invalid_utf8_string_array_attr'),
            h5_alias('invalid_utf8_string_array_vlist', h5_attr('invalid_utf8_string_array_attr', []::VARIANT[])),
            h5_alias('invalid_utf8_string_array_varray', h5_attr('invalid_utf8_string_array_attr', [NULL]::VARIANT[1]))
        ),
        'invalid_utf8_string_array_attr_dataset'
    ) AS row_value
);
