require h5db

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE type = 'dataset')
FROM h5_ls('test/data/links.h5', '/');
----
10	2

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE type = 'dataset')
FROM h5_ls('test/data/links.h5');
----
10	2

query TI
SELECT path, attr
FROM h5_ls('test/data/links.h5', '/group', h5_attr('attr', -1::INTEGER))
ORDER BY path;
----
/group/data	7

query II
SELECT COUNT(*), COUNT(*) FILTER (WHERE attr = 13)
FROM h5_ls('test/data/links.h5', h5_attr('attr', -1::INTEGER));
----
10	1

query I
SELECT cardinality(h5_ls('test/data/links.h5', '/'));
