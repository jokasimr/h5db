# name: test/sql/remote/remote_httpfs_behaviors.test
# description: Remote HTTP-specific behavior tests (auth, status errors, timeout)
# group: [remote]

require h5db

set ignore_error_messages

# =============================================================================
# Basic auth via DuckDB HTTP secret headers
# =============================================================================

statement ok
DROP SECRET IF EXISTS h5db_http_auth;

statement error
SELECT COUNT(*) FROM h5_read('test/data/auth/simple.h5', '/integers');
----
Failed to open HDF5 file: test/data/auth/simple.h5

statement ok
CREATE SECRET h5db_http_auth (
  TYPE HTTP,
  SCOPE 'test/data/auth/',
  EXTRA_HTTP_HEADERS MAP {'Authorization': 'Basic aDVkYjpkdWNrZGI='}
);

query I
SELECT COUNT(*) FROM h5_read('test/data/auth/simple.h5', '/integers');
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/auth/simple.h5');
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/with_attrs.h5', '/dataset_with_attrs');
----
1

# =============================================================================
# Remote SWMR argument behavior
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/simple.h5', '/integers', swmr := true);
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/simple.h5', swmr := true);
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/with_attrs.h5', '/dataset_with_attrs', swmr := true);
----
1

