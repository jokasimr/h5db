----

statement error
SELECT COUNT(*) FROM h5_tree('test/data/truncate/256/simple.h5');
----

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/truncate/256/with_attrs.h5', '/dataset_with_attrs');
----

statement ok
SET http_retries=3;

statement ok
SET http_retry_wait_ms=100;
