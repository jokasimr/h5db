# name: test/sql/remote/remote_httpfs_behaviors.test
# description: Remote HTTP-specific behavior tests (auth, status errors, timeout)
# group: [remote]

require h5db

# =============================================================================
# Basic auth via DuckDB HTTP secret headers
# =============================================================================

statement ok
DROP SECRET IF EXISTS h5db_http_auth;

statement error
SELECT COUNT(*) FROM h5_read('test/data/auth/simple.h5', '/integers');
----

statement ok
CREATE SECRET h5db_http_auth (
  TYPE HTTP,
  SCOPE 'test/data/auth/',
  EXTRA_HTTP_HEADERS MAP {'Authorization': 'Basic aDVkYjpkdWNrZGI='}
);

query I
SELECT COUNT(*) FROM h5_read('test/data/auth/simple.h5', '/integers');
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/auth/simple.h5');
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/with_attrs.h5', '/dataset_with_attrs');
----
1

# =============================================================================
# Remote SWMR argument behavior
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/simple.h5', '/integers', swmr := true);
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/simple.h5', swmr := true);
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/with_attrs.h5', '/dataset_with_attrs', swmr := true);
----
1

# =============================================================================
# Non-existing file
# =============================================================================

statement error
SELECT COUNT(*) FROM h5_read('test/data/does_not_exist_remote_case.h5', '/integers');
----

statement error
SELECT COUNT(*) FROM h5_tree('test/data/does_not_exist_remote_case.h5');
----

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/does_not_exist_remote_case.h5', '/dataset_with_attrs');
----

# =============================================================================
# Simulated server errors
# =============================================================================

statement error
SELECT COUNT(*) FROM h5_read('test/data/status/503/simple.h5', '/integers');
----

statement error
SELECT COUNT(*) FROM h5_tree('test/data/status/503/simple.h5');
----

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/status/503/with_attrs.h5', '/dataset_with_attrs');
----

# =============================================================================
# Retry behavior on transient server errors
# =============================================================================

statement ok
SET http_retries=3;

statement ok
SET http_retry_wait_ms=1;

query I
SELECT COUNT(*) FROM h5_read('test/data/dropflaky/2/simple.h5', '/integers');
----
10

# =============================================================================
# Redirect handling
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/redirect/307/simple.h5', '/integers');
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/redirect/307/simple.h5');
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/redirect/307/with_attrs.h5', '/dataset_with_attrs');
----
1

# =============================================================================
# Timeout behavior
# =============================================================================

statement ok
SET http_retries=0;

statement ok
SET http_timeout=1;

statement error
SELECT COUNT(*) FROM h5_read('test/data/slow/3000/simple.h5', '/integers');
----

statement error
SELECT COUNT(*) FROM h5_tree('test/data/slow/3000/simple.h5');
----

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/slow/3000/with_attrs.h5', '/dataset_with_attrs');
----

statement ok
SET http_timeout=30000;

