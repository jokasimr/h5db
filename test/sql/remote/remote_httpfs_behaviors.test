SELECT COUNT(*) FROM h5_read('test/data/corrupt/simple.h5', '/integers');
----

statement error
SELECT COUNT(*) FROM h5_tree('test/data/corrupt/simple.h5');
----

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/corrupt/with_attrs.h5', '/dataset_with_attrs');
----

statement error
