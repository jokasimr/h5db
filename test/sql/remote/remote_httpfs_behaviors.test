----
Failed to open HDF5 file: test/data/does_not_exist_remote_case.h5

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/does_not_exist_remote_case.h5', '/dataset_with_attrs');
----
Failed to open HDF5 file: test/data/does_not_exist_remote_case.h5

# =============================================================================
# Simulated server errors
# =============================================================================

statement error
SELECT COUNT(*) FROM h5_read('test/data/status/503/simple.h5', '/integers');
----
Failed to open HDF5 file: test/data/status/503/simple.h5

statement error
SELECT COUNT(*) FROM h5_tree('test/data/status/503/simple.h5');
----
Failed to open HDF5 file: test/data/status/503/simple.h5

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/status/503/with_attrs.h5', '/dataset_with_attrs');
----
Failed to open HDF5 file: test/data/status/503/with_attrs.h5

statement error
SELECT COUNT(*) FROM h5_read('test/data/status/404/simple.h5', '/integers');
----
Failed to open HDF5 file: test/data/status/404/simple.h5

# =============================================================================
# Retry behavior on transient server errors
# =============================================================================

statement ok
SET http_retries=3;

statement ok
SET http_retry_wait_ms=1;

query I
SELECT COUNT(*) FROM h5_read('test/data/dropflaky/2/simple.h5', '/integers');
----
10

query I
SELECT COUNT(*) FROM h5_read('test/data/flaky/2/503/simple.h5?case=success', '/integers');
----
10

statement ok
SET http_retries=0;

statement error
SELECT COUNT(*) FROM h5_read('test/data/dropflaky/2/simple.h5?case=fail', '/integers');
----
<REGEX>:.*(test/data/dropflaky/2/simple\.h5\?case=fail|Server returned nothing|error for HTTP (HEAD|GET)).*

statement error
SELECT COUNT(*) FROM h5_read('test/data/flaky/2/503/simple.h5?case=fail', '/integers');
----
<REGEX>:.*(test/data/flaky/2/503/simple\.h5\?case=fail|Request returned HTTP 503 for HTTP (HEAD|GET)).*

statement ok
SET http_retries=3;

# =============================================================================
# Redirect handling
# =============================================================================

query I
SELECT COUNT(*) FROM h5_read('test/data/redirect/307/simple.h5', '/integers');
----
10

query I
SELECT COUNT(*) FROM h5_tree('test/data/redirect/307/simple.h5');
----
10

query I
SELECT COUNT(*) FROM h5_attributes('test/data/redirect/307/with_attrs.h5', '/dataset_with_attrs');
----
1

# =============================================================================
# Timeout behavior
# =============================================================================

statement ok
SET http_retries=0;

statement ok
SET http_timeout=1;

statement error
SELECT COUNT(*) FROM h5_read('test/data/slow/3000/simple.h5', '/integers');
----
<REGEX>:.*(test/data/slow/3000/simple\.h5|Failed to read data from dataset: /integers).*

statement error
SELECT COUNT(*) FROM h5_tree('test/data/slow/3000/simple.h5');
----
<REGEX>:.*test/data/slow/3000/simple\.h5.*

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/slow/3000/with_attrs.h5', '/dataset_with_attrs');
----
<REGEX>:.*(test/data/slow/3000/with_attrs\.h5|Failed to open object: /dataset_with_attrs|Failed to read .*attribute:).*

statement ok
SET http_timeout=30000;

# =============================================================================
# Corrupt/truncated response bodies
# =============================================================================

# These transport-fault assertions intentionally match several failure shapes.
# The exact error stage can move between file open, object open, and later reads
# depending on where the broken response is consumed.

statement error
SELECT COUNT(*) FROM h5_read('test/data/corrupt/simple.h5', '/integers');
----
<REGEX>:.*(test/data/corrupt/simple\.h5|Failed to read data from dataset: /integers).*

statement error
SELECT COUNT(*) FROM h5_tree('test/data/corrupt/simple.h5');
----
<REGEX>:.*test/data/corrupt/simple\.h5.*

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/corrupt/with_attrs.h5', '/dataset_with_attrs');
----
<REGEX>:.*(test/data/corrupt/with_attrs\.h5|Failed to open object: /dataset_with_attrs|Failed to read .*attribute:).*

statement error
SELECT COUNT(*) FROM h5_read('test/data/truncate/256/simple.h5', '/integers');
----
<REGEX>:.*(test/data/truncate/256/simple\.h5|Failed to read data from dataset: /integers).*

statement error
SELECT COUNT(*) FROM h5_tree('test/data/truncate/256/simple.h5');
----
<REGEX>:.*test/data/truncate/256/simple\.h5.*

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/truncate/256/with_attrs.h5', '/dataset_with_attrs');
----
<REGEX>:.*(test/data/truncate/256/with_attrs\.h5|Failed to open object: /dataset_with_attrs|Failed to read .*attribute:).*

statement ok
SET http_retries=3;

statement ok
SET http_retry_wait_ms=100;
