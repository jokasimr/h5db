# name: test/sql/h5_tree_attributes.test
# description: h5_tree projected attribute columns
# group: [sql]

require h5db

# =============================================================================
# Happy-path projected attributes
# =============================================================================

query II
SELECT
    COUNT(*) FILTER (WHERE string_attr = 'Hello HDF5!'),
    COUNT(*) FILTER (WHERE string_attr IS NULL)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('string_attr', NULL::VARCHAR)
);
----
1	2

query II
SELECT
    COUNT(*) FILTER (WHERE group_int_attr = 999),
    COUNT(*) FILTER (WHERE group_int_attr = -1)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('group_int_attr', -1::BIGINT)
);
----
1	2

query II
SELECT
    COUNT(*) FILTER (WHERE int_array_attr = [1, 2, 3, 4, 5]),
    COUNT(*) FILTER (WHERE int_array_attr = [0, 0, 0, 0, 0])
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('int_array_attr', [0, 0, 0, 0, 0]::INTEGER[])
);
----
1	2

query I
SELECT time
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('time', h5_attr('group_int_attr', NULL::BIGINT))
)
WHERE path = '/group_with_attrs';
----
999

query I
SELECT string_attr
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr(lower('STRING_ATTR'), NULL::VARCHAR)
)
WHERE path = '/dataset_with_attrs';
----
Hello HDF5!

query I
SELECT COUNT(*) FILTER (WHERE missing_attr = 'missing')
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('missing_attr', 'missing'::VARCHAR)
);
----
3

query II
SELECT
    COUNT(*) FILTER (WHERE variant_typeof(string_attr) = 'VARCHAR'),
    COUNT(*) FILTER (WHERE string_attr IS NULL)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('string_attr')
);
----
1	2

query TTITI
SELECT
    path,
    typeof(h5_attr),
    cardinality(h5_attr),
    variant_typeof(map_extract_value(h5_attr, 'string_attr')),
    COALESCE(TRY_CAST(map_extract_value(h5_attr, 'group_int_attr') AS BIGINT), -1)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr()
)
ORDER BY path;
----
/	MAP(VARCHAR, VARIANT)	0	VARIANT_NULL	-1
/dataset_with_attrs	MAP(VARCHAR, VARIANT)	13	VARCHAR	-1
/group_with_attrs	MAP(VARCHAR, VARIANT)	3	VARIANT_NULL	999

query I
SELECT cardinality(attrs)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('attrs', h5_attr())
)
WHERE path = '/';
----
0

query TI
SELECT path, CASE WHEN h5_attr IS NULL THEN 1 ELSE 0 END
FROM h5_tree(
    'test/data/links.h5',
    h5_attr()
)
WHERE path IN ('/dangling_link', '/external_link')
ORDER BY path;
----
/dangling_link	1
/external_link	1

query II
SELECT
    COUNT(*) FILTER (WHERE variant_typeof(map_extract_value(h5_attr, 'enum_attr')) = 'VARIANT_NULL'),
    COUNT(*) FILTER (WHERE cardinality(h5_attr) = 1)
FROM h5_tree(
    'test/data/attrs_edge_cases.h5',
    h5_attr()
)
WHERE path = '/enum_attr_dataset';
----
1	1

query TTT
SELECT
    variant_typeof(map_extract_value(h5_attr, 'invalid_utf8_attr')),
    variant_typeof(invalid_utf8_attr),
    typeof(invalid_utf8_attr_blob)
FROM h5_tree(
    'test/data/attrs_edge_cases.h5',
    h5_attr(),
    h5_attr('invalid_utf8_attr'),
    h5_alias('invalid_utf8_attr_blob', h5_attr('invalid_utf8_attr', NULL::BLOB))
)
WHERE path = '/invalid_utf8_attr_dataset';
----
BLOB	BLOB	BLOB

query TTTTT
