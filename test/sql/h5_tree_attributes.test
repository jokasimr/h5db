/named_int32	13

query TI
SELECT path, root_number
FROM h5_tree(
    'test/data/root_attrs.h5',
    h5_attr('root_number', NULL::INTEGER)
)
WHERE path = '/';
----
/	7

query TTIII
SELECT
    typeof(labels_array),
    variant_typeof(labels_variant),
    CASE WHEN labels_array = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(labels_variant AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'labels') AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[]
        THEN 1 ELSE 0 END
FROM h5_tree(
    'test/data/root_attrs.h5',
    h5_attr(),
    h5_alias('labels_variant', h5_attr('labels')),
    h5_alias('labels_array', h5_attr('labels', ['', '', '']::VARCHAR[]))
)
WHERE path = '/string_array_attrs';
----
VARCHAR[]	ARRAY(3)	1	1	1

query TTII
SELECT
    typeof(labels_blobs),
    octet_length(array_extract(labels_blobs, 2)),
    hex(array_extract(labels_blobs, 2)),
    length(labels_blobs)
FROM h5_tree(
    'test/data/root_attrs.h5',
    h5_alias('labels_blobs', h5_attr('labels', []::BLOB[]))
)
WHERE path = '/string_array_attrs';
----
BLOB[]	2	6262	3

query TTTTIIIIII
SELECT
    typeof(empty_numbers_list),
    typeof(empty_labels_list),
    variant_typeof(empty_numbers_variant),
    variant_typeof(empty_labels_variant),
    CASE WHEN empty_numbers_list = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(empty_numbers_variant AS INTEGER[]) = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'empty_numbers') AS INTEGER[]) = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN empty_labels_list = []::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(empty_labels_variant AS VARCHAR[]) = []::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'empty_labels') AS VARCHAR[]) = []::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_tree(
    'test/data/root_attrs.h5',
    h5_attr(),
    h5_alias('empty_numbers_variant', h5_attr('empty_numbers')),
    h5_alias('empty_numbers_list', h5_attr('empty_numbers', []::INTEGER[])),
    h5_alias('empty_labels_variant', h5_attr('empty_labels')),
    h5_alias('empty_labels_list', h5_attr('empty_labels', []::VARCHAR[]))
)
WHERE path = '/empty_array_attrs';
----
INTEGER[]	VARCHAR[]	ARRAY(0)	ARRAY(0)	1	1	1	1	1	1

query TTTTIIIIII
SELECT
    typeof(fixed_numbers_list),
    typeof(fixed_labels_list),
    variant_typeof(fixed_numbers_variant),
    variant_typeof(fixed_labels_variant),
    CASE WHEN fixed_numbers_list = [1, 2, 3]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(fixed_numbers_variant AS INTEGER[]) = [1, 2, 3]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'fixed_numbers') AS INTEGER[]) = [1, 2, 3]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN fixed_labels_list = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(fixed_labels_variant AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(h5_attr, 'fixed_labels') AS VARCHAR[]) = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_tree(
    'test/data/root_attrs.h5',
    h5_attr(),
    h5_alias('fixed_numbers_variant', h5_attr('fixed_numbers')),
    h5_alias('fixed_numbers_list', h5_attr('fixed_numbers', [0, 0, 0]::INTEGER[])),
    h5_alias('fixed_labels_variant', h5_attr('fixed_labels')),
    h5_alias('fixed_labels_list', h5_attr('fixed_labels', ['', '', '']::VARCHAR[]))
)
WHERE path = '/h5t_array_attrs';
----
INTEGER[]	VARCHAR[]	ARRAY(3)	ARRAY(3)	1	1	1	1	1	1

query IIIIII
SELECT
    COUNT(*) FILTER (WHERE string_attr = 'Hello HDF5!'),
    COUNT(*) FILTER (WHERE string_attr IS NULL),
    COUNT(*) FILTER (WHERE group_int_attr = 999),
    COUNT(*) FILTER (WHERE group_int_attr = -1),
    COUNT(*) FILTER (WHERE missing_attr = 'fallback'),
    COUNT(*) FILTER (WHERE missing_attr IS NULL)
FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr('string_attr', NULL::VARCHAR),
    h5_attr('group_int_attr', -1::BIGINT),
    h5_attr('missing_attr', 'fallback'::VARCHAR)
);
----
1	2	1	2	3	0

# Duplicate projected names are rejected by DuckDB table binding.
statement error
SELECT * FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_attr(),
    h5_attr()
);
----
Binder Error: table "h5_tree" has duplicate column name "h5_attr"

statement error
SELECT * FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('dup', h5_attr('group_int_attr', NULL::BIGINT)),
    h5_alias('dup', h5_attr('group_string_attr', NULL::VARCHAR))
);
----
Binder Error: table "h5_tree" has duplicate column name "dup"

statement error
SELECT * FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('string_attr', h5_attr('group_int_attr', NULL::BIGINT)),
    h5_attr('string_attr', NULL::VARCHAR)
);
----
Binder Error: table "h5_tree" has duplicate column name "string_attr"

# Collisions with existing h5_tree column names are also rejected by DuckDB table binding.
statement error
SELECT * FROM h5_tree(
    'test/data/with_attrs.h5',
    h5_alias('path', h5_attr('group_int_attr', NULL::BIGINT))
);
----
Binder Error: table "h5_tree" has duplicate column name "path"

# =============================================================================
# Binder / argument validation
# =============================================================================

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', 'string_attr');
----
Invalid Input Error: h5_tree projected attribute arguments must be h5_attr(), h5_attr(name), h5_attr(name, default_value) or h5_alias(alias, h5_attr(...))

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', 42);
----
Invalid Input Error: h5_tree projected attribute arguments must be h5_attr(), h5_attr(name), h5_attr(name, default_value) or h5_alias(alias, h5_attr(...))

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_attr('string_attr', random()));
----
Invalid Input Error: h5_attr default_value must be a constant expression

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_attr('string_attr', NULL));
----
Invalid Input Error: h5_attr default_value must have a concrete type; use an explicit cast such as NULL::VARCHAR

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_attr(NULL::VARCHAR, NULL::VARCHAR));
----
Invalid Input Error: h5_attr name must not be NULL

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_alias('renamed', 42));
----
Invalid Input Error: h5_tree projected attribute arguments must be h5_attr(), h5_attr(name), h5_attr(name, default_value) or h5_alias(alias, h5_attr(...))

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_attr(42, NULL::VARCHAR));
----
Binder Error: No function matches the given name and argument types 'h5_attr(INTEGER_LITERAL, VARCHAR)'. You might need to add explicit type casts.

statement error
SELECT *
FROM (SELECT 'string_attr' AS attr_name) t,
     h5_tree('test/data/with_attrs.h5', h5_attr(attr_name, NULL::VARCHAR)) ht;
----
Binder Error: Table function "h5_tree" does not support lateral join column parameters - cannot use column "attr_name" in this context.

# =============================================================================
# Conversion / unsupported-type failures
# =============================================================================

statement error
SELECT * FROM h5_tree('test/data/with_attrs.h5', h5_attr('string_attr', 0::INTEGER));
----
IO Error: Attribute 'string_attr' contains values that cannot be cast to INTEGER

statement error
SELECT * FROM h5_tree(
    'test/data/attrs_edge_cases.h5',
    h5_attr('invalid_utf8_attr', NULL::VARCHAR)
);
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT * FROM h5_tree(
    'test/data/attrs_edge_cases.h5',
    h5_attr('invalid_utf8_fixed_attr', NULL::VARCHAR)
);
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

query TTTITTTITTTITTTI
SELECT
    variant_typeof(invalid_utf8_string_array_attr),
    variant_typeof(array_extract(TRY_CAST(invalid_utf8_string_array_attr AS VARIANT[]), 1)),
    hex(CAST(array_extract(TRY_CAST(invalid_utf8_string_array_attr AS VARIANT[]), 1) AS BLOB)),
    length(TRY_CAST(invalid_utf8_string_array_attr AS VARIANT[])),
    typeof(invalid_utf8_string_array_vlist),
    variant_typeof(array_extract(invalid_utf8_string_array_vlist, 1)),
    hex(CAST(array_extract(invalid_utf8_string_array_vlist, 1) AS BLOB)),
    length(invalid_utf8_string_array_vlist),
    typeof(invalid_utf8_string_array_varray),
    variant_typeof(array_extract(invalid_utf8_string_array_varray, 1)),
    hex(CAST(array_extract(invalid_utf8_string_array_varray, 1) AS BLOB)),
    length(invalid_utf8_string_array_varray),
    variant_typeof(map_extract_value(h5_attr, 'invalid_utf8_string_array_attr')),
    variant_typeof(array_extract(TRY_CAST(map_extract_value(h5_attr, 'invalid_utf8_string_array_attr') AS VARIANT[]), 1)),
    hex(CAST(array_extract(TRY_CAST(map_extract_value(h5_attr, 'invalid_utf8_string_array_attr') AS VARIANT[]), 1) AS BLOB)),
    length(TRY_CAST(map_extract_value(h5_attr, 'invalid_utf8_string_array_attr') AS VARIANT[]))
FROM h5_tree(
    'test/data/invalid_string_array_attrs.h5',
    h5_attr(),
    h5_attr('invalid_utf8_string_array_attr'),
    h5_alias('invalid_utf8_string_array_vlist', h5_attr('invalid_utf8_string_array_attr', []::VARIANT[])),
    h5_alias('invalid_utf8_string_array_varray', h5_attr('invalid_utf8_string_array_attr', [NULL]::VARIANT[1]))
)
WHERE path = '/invalid_utf8_string_array_attr_dataset';
----
ARRAY(1)	BLOB	FFFE	1	VARIANT[]	BLOB	FFFE	1	VARIANT[1]	BLOB	FFFE	1	ARRAY(1)	BLOB	FFFE	1

