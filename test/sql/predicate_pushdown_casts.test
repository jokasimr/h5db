# name: test/sql/predicate_pushdown_casts.test
# description: Regression tests for predicate pushdown through comparison casts
# group: [sql]

require h5db

# =============================================================================
# uint64 RSE column with foldable integer expressions on the RHS
# =============================================================================

statement ok
PRAGMA enable_profiling='json';

statement ok
PRAGMA profiling_output='/tmp/h5db_pushdown_cast_profile.json';

query I
SELECT COUNT(*)
FROM h5_read(
    'test/data/multithreading_test.h5',
    '/detector_1/time_offset',
    h5_rse('/detector_1/event_index', '/detector_1/event_time_zero')
)
WHERE event_time_zero > 1001250000 - 1;
----
500

statement ok
PRAGMA disable_profiling;

query I
SELECT COUNT(*)
FROM read_text('/tmp/h5db_pushdown_cast_profile.json')
WHERE contains(content, '"Expression": "(CAST(event_time_zero AS HUGEINT) > 1001249999)"');
----
1

query I
SELECT COUNT(*)
FROM read_text('/tmp/h5db_pushdown_cast_profile.json')
WHERE contains(
    substr(content, greatest(strpos(content, '"operator_name": "H5_READ"') - 260, 1), 520),
    '"operator_cardinality": 500'
);
----
1

