# name: test/sql/attrs_edge_cases.test
# description: Attribute edge cases (empty attrs, vlen strings, multidim)
# group: [sql]

require h5db

# =============================================================================
# Empty attributes
# =============================================================================

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/empty_dataset');
----
IO Error: Object has no attributes: /empty_dataset

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/empty_group');
----
IO Error: Object has no attributes: /empty_group

statement error
SELECT * FROM h5_attributes('test/data/root_attrs.h5', NULL::VARCHAR);
----
Invalid Input Error: h5_attributes path must not be NULL

# =============================================================================
# String attribute handling (vlen + fixed)
# =============================================================================

query TT
SELECT vlen_str_attr, fixed_str_attr
FROM h5_attributes('test/data/attrs_edge_cases.h5', '/string_attrs');
----
variable	fixed

query IT
SELECT octet_length(CAST(nullpad_attr AS BLOB)), hex(CAST(nullpad_attr AS BLOB))
FROM h5_attributes('test/data/attrs_edge_cases.h5', '/nullpad_attr_dataset');
----
3	410042

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/invalid_utf8_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT COUNT(*) FROM h5_attributes('test/data/attrs_edge_cases.h5', '/invalid_utf8_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/invalid_utf8_fixed_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT * FROM h5_attributes('test/data/invalid_string_array_attrs.h5', '/invalid_utf8_string_array_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT * FROM h5_attributes('test/data/invalid_string_array_attrs.h5', '/invalid_utf8_vlen_string_array_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/invalid_utf8_after_nul_attr_dataset');
----
IO Error: Invalid unicode (byte sequence mismatch) detected in value construction

# Root attributes should work for both '/' and ''.
query TI
SELECT root_name, root_number
FROM h5_attributes('test/data/root_attrs.h5', '/');
----
root	7

query TI
SELECT root_name, root_number
FROM h5_attributes('test/data/root_attrs.h5', '');
----
root	7

query TTI
SELECT
    typeof(labels),
    array_extract(labels, 2),
    CASE WHEN labels = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/string_array_attrs');
----
VARCHAR[]	bb	1

query TITI
SELECT
    typeof(empty_numbers),
    length(empty_numbers),
    typeof(empty_labels),
    length(empty_labels)
FROM h5_attributes('test/data/root_attrs.h5', '/empty_array_attrs');
----
INTEGER[]	0	VARCHAR[]	0

query II
SELECT
    CASE WHEN empty_numbers = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN empty_labels = []::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/empty_array_attrs');
----
1	1

query TITITI
SELECT
    typeof(fixed_numbers),
    length(fixed_numbers),
    CASE WHEN fixed_numbers = [1, 2, 3]::INTEGER[] THEN 1 ELSE 0 END,
    typeof(fixed_labels),
    length(fixed_labels),
    CASE WHEN fixed_labels = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/h5t_array_attrs');
----
INTEGER[]	3	1	VARCHAR[]	3	1

