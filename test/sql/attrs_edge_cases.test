    typeof(float16_attr),
    float16_attr,
    typeof(float16_list_attr),
    CASE WHEN float16_list_attr = [1.5, 2.5]::FLOAT[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/attrs_edge_cases.h5', '/float16_attr_dataset');
----
FLOAT	1.5	FLOAT[]	1

