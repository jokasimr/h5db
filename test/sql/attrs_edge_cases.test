# Root attributes should work for both '/' and ''.
query TI
SELECT root_name, root_number
FROM h5_attributes('test/data/root_attrs.h5', '/');
----
root	7

query TI
SELECT root_name, root_number
FROM h5_attributes('test/data/root_attrs.h5', '');
----
root	7

query TTI
SELECT
    typeof(labels),
    array_extract(labels, 2),
    CASE WHEN labels = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/string_array_attrs');
----
VARCHAR[]	bb	1

query TITI
SELECT
    typeof(empty_numbers),
    length(empty_numbers),
    typeof(empty_labels),
    length(empty_labels)
FROM h5_attributes('test/data/root_attrs.h5', '/empty_array_attrs');
----
INTEGER[]	0	VARCHAR[]	0

query II
SELECT
    CASE WHEN empty_numbers = []::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN empty_labels = []::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/empty_array_attrs');
----
1	1

query TITITI
SELECT
    typeof(fixed_numbers),
    length(fixed_numbers),
    CASE WHEN fixed_numbers = [1, 2, 3]::INTEGER[] THEN 1 ELSE 0 END,
    typeof(fixed_labels),
    length(fixed_labels),
    CASE WHEN fixed_labels = ['a', 'bb', 'ccc']::VARCHAR[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/root_attrs.h5', '/h5t_array_attrs');
----
INTEGER[]	3	1	VARCHAR[]	3	1

# =============================================================================
# Numeric attributes with explicit file byte order
# =============================================================================

query IIIIIIII
SELECT
    be_int32,
    le_int32,
    CASE WHEN be_float64 = 1234.5 THEN 1 ELSE 0 END,
    CASE WHEN le_float64 = 1234.5 THEN 1 ELSE 0 END,
    CASE WHEN be_int32_list = [1, 256, 65537]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN le_int32_list = [1, 256, 65537]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN be_int32_h5t_array = [1, 256, 65537]::INTEGER[] THEN 1 ELSE 0 END,
    CASE WHEN le_int32_h5t_array = [1, 256, 65537]::INTEGER[] THEN 1 ELSE 0 END
FROM h5_attributes('test/data/endian_attrs.h5', '/values');
----
16909060	16909060	1	1	1	1	1	1

query III
SELECT
    TRY_CAST(map_extract_value(attrs, 'be_int32') AS INTEGER),
    CASE WHEN TRY_CAST(map_extract_value(attrs, 'be_int32_list') AS INTEGER[]) = [1, 256, 65537] THEN 1 ELSE 0 END,
    CASE WHEN TRY_CAST(map_extract_value(attrs, 'be_int32_h5t_array') AS INTEGER[]) = [1, 256, 65537] THEN 1 ELSE 0 END
FROM (
    SELECT h5_attributes('test/data/endian_attrs.h5', '/values') AS attrs
);
----
16909060	1	1

