# name: test/sql/attrs_edge_cases.test
# description: Attribute edge cases (empty attrs, vlen strings, multidim)
# group: [sql]

require h5db

# =============================================================================
# Empty attributes
# =============================================================================

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/empty_dataset');
----
IO Error: Object has no attributes: /empty_dataset in file: test/data/attrs_edge_cases.h5

statement error
SELECT * FROM h5_attributes('test/data/attrs_edge_cases.h5', '/empty_group');
----
IO Error: Object has no attributes: /empty_group in file: test/data/attrs_edge_cases.h5

statement error
SELECT * FROM h5_attributes('test/data/root_attrs.h5', NULL::VARCHAR);
----
Invalid Input Error: h5_attributes path must not be NULL

query TI
SELECT typeof(h5_attributes('test/data/attrs_edge_cases.h5', '/empty_group')),
       cardinality(h5_attributes('test/data/attrs_edge_cases.h5', '/empty_group'));
----
MAP(VARCHAR, VARIANT)	0

query TTI
SELECT
    variant_typeof(map_extract_value(h5_attributes('test/data/root_attrs.h5', '/'), 'root_name')),
    TRY_CAST(map_extract_value(h5_attributes('test/data/root_attrs.h5', '/'), 'root_name') AS VARCHAR),
    TRY_CAST(map_extract_value(h5_attributes('test/data/root_attrs.h5', '/'), 'root_number') AS INTEGER);
----
VARCHAR	root	7

query I
SELECT cardinality(h5_attributes('test/data/root_attrs.h5', ''));
----
2

query TII
WITH paths(path) AS (
    VALUES ('/string_attrs'), ('/empty_group'), (NULL::VARCHAR)
),
attrs AS (
    SELECT path, h5_attributes('test/data/attrs_edge_cases.h5', path) AS value
    FROM paths
)
SELECT
    COALESCE(path, '<null>') AS path,
    CASE WHEN value IS NULL THEN 1 ELSE 0 END AS is_null,
    CASE WHEN value IS NULL THEN -1 ELSE cardinality(value) END AS attr_count
FROM attrs
ORDER BY path;
----
/empty_group	0	0
/string_attrs	0	2
<null>	1	-1

query TII
WITH inputs(filename, path) AS (
    VALUES
        ('test/data/root_attrs.h5', '/'),
        ('test/data/attrs_edge_cases.h5', '/empty_group'),
        (NULL::VARCHAR, '/')
),
attrs AS (
    SELECT filename, h5_attributes(filename, path) AS value
    FROM inputs
)
SELECT
    COALESCE(filename, '<null>') AS filename,
    CASE WHEN value IS NULL THEN 1 ELSE 0 END AS is_null,
    CASE WHEN value IS NULL THEN -1 ELSE cardinality(value) END AS attr_count
FROM attrs
ORDER BY filename;
----
<null>	1	-1
test/data/attrs_edge_cases.h5	0	0
test/data/root_attrs.h5	0	2

